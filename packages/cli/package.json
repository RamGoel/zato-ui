{
  "name": "zatoui",
  "version": "0.1.4",
  "description": "CLI for adding AI chat UI components to your project",
  "keywords": [
    "ai",
    "chat",
    "ui",
    "components",
    "shadcn",
    "react",
    "nextjs"
  ],
  "author": "Ram Goel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RamGoel/zato-ui"
  },
  "homepage": "https://zatoui.dev",
  "type": "module",
  "bin": {
    "zato": "./dist/index.js"
